datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Vehicle {
  plate       String   @id
  name        String
  year        String
  status      String
  odometer    String
  driver      String
  lastService String
  company     String
}

model Driver {
  id           String   @id
  name         String
  license      String
  contact      String
  status       String
  dlExpiry     String
  hazmatValid  String
  eyeTestDate  String
  company      String
}

model Schedule {
  id      String @id
  vehicle String
  task    String
  date    String
  status  String
  company String
}

model Compliance {
  id          String @id
  vehicle     String
  type        String
  status      String
  renewalDate String
  company     String
}

model User {
  phone   String @id
  name    String
  company String
}
